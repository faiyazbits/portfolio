NEXT_PUBLIC_WHATSAPP_URL=https://wa.me/<country-code><number>?text=<url-encoded-message>
NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/<username>/<event-slug>

# Resend — email sending and contact management
# Sign up at resend.com, verify your domain, generate an API key
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# The "from" address shown on all outgoing emails (must be on a verified domain)
RESEND_FROM_EMAIL=noreply@yourdomain.com

# Full URL of the site — used to build the PDF download link in emails
NEXT_PUBLIC_SITE_URL=https://yourdomain.com
